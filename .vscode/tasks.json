{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev shell",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "npm",
        "pattern": {
          "regexp": "$^"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:|ready in"
        }
      }
    }
  ]
}