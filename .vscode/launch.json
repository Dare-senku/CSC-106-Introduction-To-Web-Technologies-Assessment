{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Local:\\s+(https?://\\S+)"
      }
    }
  ],
  "compounds": [
    {
      "name": "Run + Debug",
      "configurations": ["npm: dev shell", "Launch Chrome"],
      "stopAll": true,
      "preLaunchTask": "npm: dev shell"
    }
  ]
}